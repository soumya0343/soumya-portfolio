# Copy this file to .env and fill in your values

# --- Contact form (server-side; set in Vercel project env, NOT prefixed with VITE_) ---
# Resend sends the form message to your inbox. Free tier: 3,000 emails/mo.
RESEND_API_KEY=your_resend_api_key_here
# CONTACT_TO=soumya0343@gmail.com
# Default sender onboarding@resend.dev only delivers to the Resend account owner.
# Verify a domain in Resend to send from your own address:
# CONTACT_FROM=Portfolio <hello@yourdomain.com>

# --- Ask my AI (server-side; set these in Vercel project env, NOT prefixed with VITE_) ---
# Provider-agnostic: any OpenAI-compatible /chat/completions API. All have free tiers.
# Pick ONE provider and set LLM_API_KEY (+ optionally override base/model).
LLM_API_KEY=your_free_provider_key_here

# Google Gemini (default — free tier, generous):
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   LLM_MODEL=gemini-2.5-flash
# Groq (free, very fast):
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile
# Cerebras (free, fast):
#   LLM_BASE_URL=https://api.cerebras.ai/v1
#   LLM_MODEL=llama-3.3-70b
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
