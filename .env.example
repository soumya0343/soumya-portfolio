# Copy this file to .env and fill in your values
VITE_WEB3FORMS_KEY=your_web3forms_access_key_here

# --- Ask my AI (server-side; set these in Vercel project env, NOT prefixed with VITE_) ---
# Provider-agnostic: any OpenAI-compatible /chat/completions API. All have free tiers.
# Pick ONE provider and set LLM_API_KEY (+ optionally override base/model).
LLM_API_KEY=your_free_provider_key_here

# Google Gemini (default — free tier, generous):
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   LLM_MODEL=gemini-2.5-flash
# Groq (free, very fast):
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile
# Cerebras (free, fast):
#   LLM_BASE_URL=https://api.cerebras.ai/v1
#   LLM_MODEL=llama-3.3-70b
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
